# ============================================================================
# MorningEdge — .gitignore
# Standard Python ignores + project-specific bits
# ============================================================================

# --- Secrets ---
.env
.env.local
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Data & model artifacts (regenerated from pipeline) ---
data/*.duckdb
data/*.duckdb.wal
data/raw/
data/processed/
data/cache/
models/
*.parquet

# --- Hugging Face / Torch caches ---
.cache/
.huggingface/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Streamlit ---
.streamlit/secrets.toml

# --- Notebooks ---
.ipynb_checkpoints/

# --- Test / coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Logs ---
*.log
logs/
