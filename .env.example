# ============================================================================
# MorningEdge — environment variables
# Copy this file to `.env` and fill in your real values. Never commit `.env`.
# ============================================================================

# --- Google Gemini API (free tier) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Optional free news APIs (Week 1 will tell us which we actually use) ---
# https://finnhub.io/register  (free tier)
FINNHUB_API_KEY=

# https://www.marketaux.com/  (free tier — 100 requests/day)
MARKETAUX_API_KEY=

# --- App config ---
LOG_LEVEL=INFO
DUCKDB_PATH=data/morningedge.duckdb
